{
  "name": "jjfo-hrms-backend",
  "version": "1.1.0",
  "description": "JJFO HRMS API",
  "main": "server.js",
  "scripts": {
    "dev": "node --env-file=.env --watch server.js",
    "start": "node --env-file=.env server.js",
    "seed": "node --env-file=.env seed.js",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:generate": "npx prisma generate",
    "test:smoke": "node --env-file=.env test/smoke.mjs",
    "test": "npm run test:smoke"
  },
  "keywords": ["hrms", "jjfo"],
  "author": "JJFO",
  "license": "UNLICENSED",
  "private": true,
  "type": "commonjs",
  "dependencies": {
    "@prisma/client": "^6.4.1",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.2.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "prisma": "^6.4.1"
  }
}
