# Required: min 32 characters
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-chars

# API
PORT=4000
NODE_ENV=development

# Vite dev origin (must match browser URL for CORS + cookies)
CLIENT_ORIGIN=http://localhost:5173

# Prisma / SQLite (relative to prisma/ folder)
DATABASE_URL=file:./dev.db

# Optional: allow hard-delete of employees via DELETE /api/employees/:id
# ALLOW_HARD_DELETE=1
